{
  "exclude": ["build", "node_modules", "src/code-system/cts-metadata.json"],
  "include": ["src", "test"],
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2017",
    "lib": ["ESNext", "DOM"],
    "types": ["node", "jest"],
    "module": "nodenext",
    "allowJs": true,
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "isolatedModules": true
  },
  "ts-node": {
    "files": true
  }
}
